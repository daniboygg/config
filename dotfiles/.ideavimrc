" .ideavimrc is a configuration file for IdeaVim plugin. It uses
"   the same commands as the original .vimrc configuration.
" You can find a list of commands here: https://jb.gg/h38q75
" Find more examples here: https://jb.gg/share-ideavimrc


"" -- Suggested options --
" Show a few lines of context around the cursor. Note that this makes the
" text scroll if you mouse-click near the start or end of the window.
set scrolloff=5

" Do incremental searching.
set incsearch

" Don't use Ex mode, use Q for formatting.
map Q gq

let mapleader=" "

" --- Enable IdeaVim plugins https://jb.gg/ideavim-plugins

" Highlight copied text
Plug 'machakann/vim-highlightedyank'
" Commentary plugin
Plug 'tpope/vim-commentary'


"" -- Map IDE actions to IdeaVim -- https://jb.gg/abva4t
"" Map \r to the Reformat Code action
"map \r <Action>(ReformatCode)

"" Map <leader>d to start debug
"map <leader>d <Action>(Debug)

"" Map \b to toggle the breakpoint on the current line
"map \b <Action>(ToggleLineBreakpoint)

set showmodewidget
set clipboard+=unnamed
set number
set relativenumber
set ignorecase
set clipboard+=unnamedplus
set ideajoin
set hlsearch
nmap <Esc> :nohlsearch<CR>

" [S]earch [F]iles
nmap <leader>sf <Action>(GotoFile)
" [S]earch [S]ymbols
nmap <leader>ss <Action>(FileStructurePopup)
" [S]earch [P]project [S]ymbols
nmap <leader>sps <Action>(GotoSymbol)
" [S]earch [G]rep search content in files
nmap <leader>sg <Action>(FindInPath)
" Search recent files (from telescope space space)
nmap <leader><leader> <Action>(RecentFiles)

" Split [V] vertical to other tab
nmap <leader>v <Action>(SplitVertically)
" [Q]uit tab
nmap <leader>q <Action>(CloseContent)
" Panel navigation
nmap <C-h> <C-w>h
nmap <C-l> <C-w>l

" [L]sp [R]ename
nmap <leader>lr <Action>(RenameElement)

" [Y]ank [R]reference CopyReference
nmap <leader>yr <Action>(CopyReference)

" go to [T]erminal
nmap <leader>t <Action>(ActivateTerminalToolWindow)
" go to commit panel
nmap <leader>gk <Action>(CheckinProject)
" [G]i[t] [D]iff with same version
nmap <leader>gtd <Action>(Compare.SameVersion)

" [R]un [R]un run default selected project
nmap <leader>r <Action>(Run)
" [R]un [D]ebug debug selected project
nmap <leader>d <Action>(Debug)

" [D]ebug [B]reakpoint
nmap <leader>db <Action>(ToggleLineBreakpoint)
" [D]ebug [A]advance advance when execution is passed on point
nmap <leader>da <Action>(StepOver)
" [D]ebug [I]into advance stepping into function
nmap <leader>di <Action>(StepInto)
" [D]ebug [C]continue continue execution
nmap <leader>dc <Action>(Resume)
" [D]ebug [H]ere advance execution to current line
nmap <leader>dh <Action>(RunToCursor)


